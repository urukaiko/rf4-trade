# Caddy configuration — PRODUCTION
#
# Domain is read from the DOMAIN environment variable.
# Set DOMAIN in .env on the VPS (e.g. DOMAIN=rf4trade.com).
#
# Caddy will automatically provision TLS certificates via Let's Encrypt.
#
# Used by: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

{$DOMAIN} {
    # Compress responses
    encode gzip zstd

    # 1. Serve static images directly from disk (fast, bypasses Bun)
    handle /images/* {
        root * /srv/static
        file_server
    }

    # 2. Forward all other requests to the SvelteKit container
    handle {
        reverse_proxy app:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Structured logs for production monitoring
    log {
        output stdout
        format console
    }
}