# Caddy configuration — PRODUCTION
#
# Replace "yourdomain.example.com" with your actual domain.
# Caddy will automatically provision TLS certificates via Let's Encrypt.
#
# Used by: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

yourdomain.example.com {
    # Compress responses
    encode gzip zstd

    # Forward all requests to the SvelteKit container on port 3000
    reverse_proxy app:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Structured logs for production monitoring
    log {
        output stdout
        format console
    }
}