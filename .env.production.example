# ============================================================
# Production environment variables — copy to .env and fill in values
# ============================================================

# Database
# Use the Docker service name (db) as the host in DATABASE_URL
POSTGRES_USER=rf4user
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=rf4trade
DATABASE_URL="postgresql://rf4user:<strong-random-password>@db:5432/rf4trade?sslmode=disable"

# Application
NODE_ENV=production
PORT=3000
# Must match the public-facing URL (no trailing slash)
ORIGIN="https://yourdomain.example.com"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<output-of-openssl-rand-base64-32>
# Internal URL — matches what the app binds to (used by Better Auth for redirects)
BETTER_AUTH_URL="https://yourdomain.example.com"
# Client-side URL — must be the public HTTPS URL for the browser
VITE_BETTER_AUTH_URL="https://yourdomain.example.com"

# ============================================================
# HTTPS / TLS Configuration
# ============================================================
# Caddy (in docker-compose) handles TLS automatically via Let's Encrypt.
# Ensure:
#   1. yourdomain.example.com DNS A record points to your server IP
#   2. Port 80 and 443 are open on your firewall
#   3. Caddyfile has your actual domain (not localhost)
#   4. ORIGIN, BETTER_AUTH_URL, and VITE_BETTER_AUTH_URL all use https://
#
# For multi-instance production deployments:
#   - Use Redis for rate limiting instead of in-memory Map (hooks.server.ts)
#   - Consider external session storage for horizontal scaling
# ============================================================
