# ============================================================
# Production environment variables — copy to .env and fill in values
# ============================================================
# This file goes on the VPS at /opt/rf4-trade/.env
# It is the ONLY file with secrets — never commit real values!
# ============================================================

# ---------- Domain ----------
# Your actual domain name (no protocol, no trailing slash)
# Used by Caddy for TLS certificate provisioning via Let's Encrypt
DOMAIN=yourdomain.example.com

# ---------- Database ----------
# Use the Docker service name (db) as the host in DATABASE_URL
POSTGRES_USER=rf4user
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=rf4trade
DATABASE_URL="postgresql://rf4user:<strong-random-password>@db:5432/rf4trade?sslmode=disable"

# ---------- Application ----------
NODE_ENV=production
PORT=3000
# Must match the public-facing URL (no trailing slash)
ORIGIN="https://yourdomain.example.com"

# ---------- GitHub Container Registry ----------
# Used by docker-compose.prod.yml to pull the image
# Format: github-username/repository-name (lowercase)
GITHUB_REPO=your-github-username/rf4-trade

# ---------- Better Auth ----------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<output-of-openssl-rand-base64-32>

# Server-side URL — matches what the app binds to
BETTER_AUTH_URL="https://yourdomain.example.com"

# Client-side URL — must be the public HTTPS URL for the browser
VITE_BETTER_AUTH_URL="https://yourdomain.example.com"
