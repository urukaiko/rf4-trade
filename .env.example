# ============================================================
# Environment variables — copy to .env and fill in values
# ============================================================

# Database
POSTGRES_USER=rf4user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rf4trade
DATABASE_URL="postgresql://rf4user:rf4pass@localhost:5432/rf4trade?sslmode=disable"

# Test database URL (auto-used by `bun run test` script)
# Override this if your Postgres credentials differ
DATABASE_URL_TEST="postgresql://rf4user:rf4pass@localhost:5432/rf4trade_test"

# Application
NODE_ENV=development
PORT=3000
ORIGIN="http://localhost:3000"

# Better Auth
BETTER_AUTH_SECRET='generate-a-32-char-random-string'
BETTER_AUTH_URL='http://localhost:3000'
VITE_BETTER_AUTH_URL='http://localhost:5173'
