# ============================================================
# Environment variables — copy to .env and fill in values
# ============================================================

# ---------- Database ----------
POSTGRES_USER=rf4user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rf4trade

# Main database connection string (used by the app at runtime)
DATABASE_URL="postgresql://rf4user:changeme@localhost:5432/rf4trade?sslmode=disable"

# Test database for vitest (used by `bun run test` and `bun run test:setup`)
DATABASE_URL_TEST="postgresql://rf4user:changeme@localhost:5432/rf4trade_test"

# ---------- Application ----------
NODE_ENV=development
PORT=3000
# SvelteKit ORIGIN — used for adapter and CORS. Must match the public-facing URL.
ORIGIN="http://localhost:3000"

# ---------- Better Auth ----------
# BETTER_AUTH_SECRET — server-side secret for signing tokens.
#   Generate with: openssl rand -base64 32
#   Minimum 32 characters. Never commit real values to Git.
BETTER_AUTH_SECRET='generate-a-32-char-random-string'

# BETTER_AUTH_URL — server-side URL (used by Bun/SvelteKit on the server).
#   In dev: http://localhost:3000 (the running app)
BETTER_AUTH_URL='http://localhost:3000'

# VITE_BETTER_AUTH_URL — client-side URL (compiled into the browser bundle by Vite).
#   In dev: http://localhost:5173 (Vite dev server, different port from the app)
#   In prod: same as BETTER_AUTH_URL (both should be https://yourdomain.com)
VITE_BETTER_AUTH_URL='http://localhost:5173'