# ============================================================
# Environment variables — copy to .env and fill in values
# ============================================================

# ---------- Database ----------
POSTGRES_USER=rf4user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rf4trade

# Main database connection string (used by the app at runtime)
DATABASE_URL="postgresql://rf4user:changeme@localhost:5432/rf4trade?sslmode=disable"

# Test database for vitest (used by `bun run test`)
DATABASE_URL_TEST="postgresql://rf4user:changeme@localhost:5432/rf4trade_test"

# ---------- Application ----------
NODE_ENV=development
PORT=3000

# SvelteKit ORIGIN — used by the adapter for CORS and absolute URLs.
# Must match the public-facing URL (no trailing slash).
ORIGIN="http://localhost:3000"

# Vite dev server bind address.
# - "localhost" (default) — local access only
# - "0.0.0.0" — accessible from LAN, ZeroTier, and other devices
# Uncomment to share the dev server with other machines:
# VITE_HOST=0.0.0.0

# ---------- Better Auth ----------
# Server-side secret for signing tokens and sessions.
# Generate with: openssl rand -base64 32
# Minimum 32 characters. Never commit real values to Git.
BETTER_AUTH_SECRET='generate-a-32-char-random-string'

# Server-side auth URL (used by Bun/SvelteKit on the server).
# In dev: points to the running app on port 3000.
BETTER_AUTH_URL='http://localhost:3000'

# Client-side auth URL (compiled into the browser bundle by Vite).
# In dev: points to the Vite dev server on port 5173.
# In prod: must match BETTER_AUTH_URL (both https://yourdomain.com).
VITE_BETTER_AUTH_URL='http://localhost:5173'